# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=info@getaticket.co.uk

# Sender address
# Testing (Resend sandbox — can only deliver to your Resend account email):
# CONTACT_FROM_EMAIL=Get A Ticket <onboarding@resend.dev>
# CONTACT_TO_EMAIL=your-resend-account@email.com
#
# Production (after verifying getaticket.co.uk at https://resend.com/domains):
CONTACT_FROM_EMAIL=Get A Ticket <noreply@getaticket.co.uk>
